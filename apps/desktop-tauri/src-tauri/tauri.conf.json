{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent-Trace",
  "version": "0.5.0",
  "identifier": "dev.agent-trace.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agent-Trace",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:4319; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["../assets/icon.ico"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
