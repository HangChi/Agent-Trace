{
  "name": "@agent-trace/desktop-tauri",
  "version": "0.5.0",
  "private": true,
  "scripts": {
    "build": "tauri build",
    "build:ui": "vite build",
    "build:exe": "tauri build --no-bundle",
    "dev": "tauri dev",
    "dev:ui": "vite --host 127.0.0.1 --port 1420",
    "lint": "node scripts/check-ui.mjs && pnpm run typecheck && cargo clippy -p agent-trace-desktop --all-targets -- -D warnings",
    "test": "node scripts/check-ui.mjs && pnpm run typecheck && cargo test -p agent-trace-core",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agent-trace/dashboard-ui": "workspace:*",
    "@agent-trace/schema": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
