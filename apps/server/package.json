{
  "name": "@agent-trace/server",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:init": "tsx src/init-db.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "pnpm run typecheck",
    "smoke:read-model": "tsx src/read-model.smoke.ts",
    "smoke": "tsx src/smoke.ts",
    "smoke:start": "tsx src/start.smoke.ts",
    "test": "tsx src/migrations.smoke.ts && tsx src/smoke.ts && tsx src/start.smoke.ts && tsx src/read-model.smoke.ts && tsx src/trace-insights.smoke.ts && tsx src/usage-api.smoke.ts && tsx src/usage-storage.smoke.ts && tsx src/transcript-api.smoke.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "@agent-trace/schema": "workspace:*",
    "better-sqlite3": "^12.5.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.1",
    "js-tiktoken": "^1.0.21"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.2",
    "tsx": "^4.21.0"
  }
}
