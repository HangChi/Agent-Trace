{
  "name": "agent-trace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.7",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11.0.7 <12"
  },
  "scripts": {
    "build": "pnpm -r build",
    "desktop:build:win": "pnpm --filter @agent-trace/desktop-tauri build",
    "desktop:build:electron:win": "node apps/desktop/scripts/package-win.mjs nsis",
    "desktop:check:rust": "cargo test -p agent-trace-core && cargo clippy --workspace --all-targets -- -D warnings",
    "desktop:dev": "pnpm --filter @agent-trace/desktop-tauri dev",
    "desktop:dev:electron": "pnpm --filter @agent-trace/desktop dev",
    "desktop:pack:win": "pnpm --filter @agent-trace/desktop-tauri build -- --no-bundle",
    "desktop:pack:electron:win": "node apps/desktop/scripts/package-win.mjs dir",
    "dev": "pnpm -r --parallel dev",
    "format": "pnpm -r format",
    "docs:check": "node scripts/docs-check.mjs",
    "lint": "node scripts/workspace-scripts.smoke.mjs && node scripts/docs-check.mjs && pnpm -r lint && git diff --check",
    "prepare": "pnpm --filter @agent-trace/schema build",
    "pretest": "pnpm --filter @agent-trace/schema build",
    "test": "node scripts/workspace-scripts.smoke.mjs && node --test scripts/workspace-scripts.test.mjs && pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "verify": "pnpm build && pnpm test && pnpm typecheck && pnpm lint"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
