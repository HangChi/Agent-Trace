{
  "name": "agent-trace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.7",
  "scripts": {
    "build": "pnpm -r build",
    "desktop:build:win": "node apps/desktop/scripts/package-win.mjs nsis",
    "desktop:dev": "pnpm --filter @agent-trace/desktop dev",
    "desktop:pack:win": "node apps/desktop/scripts/package-win.mjs dir",
    "dev": "pnpm -r --parallel dev",
    "format": "pnpm -r format",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
